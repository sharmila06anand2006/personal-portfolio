# =====================
# ENVIRONMENT VARIABLES
# =====================

# MongoDB Connection String
# Get this from MongoDB Atlas:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a cluster
# 3. Click "Connect" and copy the connection string
# 4. Replace <password> with your database password
# 5. Replace myFirstDatabase with your database name

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<database-name>?retryWrites=true&w=majority

# Server Port
# The port where your Express server will run
# Default: 5000
PORT=5000

# Node Environment
# Set to 'development' for local testing
# Set to 'production' for deployment
NODE_ENV=development
